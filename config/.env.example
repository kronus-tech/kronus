# ─── Kronus Configuration ──────────────────────────────────────────────────
# These are set automatically during setup (./scripts/install.sh)
# You can also edit them manually.

# Your name — personalizes your AI assistant
KRONUS_OWNER=your_name

# Your profession — configures folder structure and suggestions
# Options: developer, researcher, lawyer, consultant, business, writer, student, general
KRONUS_PROFESSION=general

# ─── Phone Access (Telegram) ──────────────────────────────────────────────
# Get a bot token from @BotFather on Telegram (free, takes 2 minutes)
# Leave empty if you only want to use Kronus from your computer
TELEGRAM_BOT_TOKEN=

# ─── Knowledge Base ───────────────────────────────────────────────────────
# Where your notes and AI memories are stored
# Format: path|label,path|label
# Default: ~/second-brain for your notes, ~/.claude/projects for AI memories
BRAIN_ROOTS=~/second-brain|personal,~/.claude/projects|project
BRAIN_DB=~/.kronus/brain.sqlite
BRAIN_UI_PORT=4242

# ─── Optional ─────────────────────────────────────────────────────────────
# Anthropic key (only needed if not using Claude Code subscription)
# ANTHROPIC_API_KEY=sk-ant-...
